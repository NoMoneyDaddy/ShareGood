// ShareGood M0 schema — 表清單見 docs/plan/master-plan.md §5 與 §11.1
// 慣例：model PascalCase 單數、DB 表 snake_case 複數（@@map）、欄位 camelCase（@map 成 snake_case）

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // 連線字串在 prisma.config.ts（Prisma 7 起 url 不放 schema）
}

// ===== Auth.js（@auth/prisma-adapter 標準模型） =====

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts       Account[]
  sessions       Session[]
  profile        Profile?
  roles          UserRole[]
  auditLogs      AuditLog[]      @relation("AuditActor")
  storageObjects StorageObject[]

  items                   Item[]
  itemStatusLogsActed     ItemStatusLog[]
  claimComments           ClaimComment[]
  directSharesReceived    DirectShare[]
  handoverRecords         HandoverRecord[]
  thanksSent              ThanksMessage[]      @relation("ThanksSent")
  thanksReceived          ThanksMessage[]      @relation("ThanksReceived")
  contributionEvents      ContributionEvent[]
  notifications           Notification[]
  conversationMemberships ConversationMember[]
  messagesSent            Message[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ===== 個人資料與權限 =====

model Profile {
  userId    String   @id @map("user_id")
  nickname  String
  cityId    String?  @map("city_id")
  bio       String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  city City? @relation(fields: [cityId], references: [id])

  @@map("profiles")
}

enum Role {
  user
  moderator
  admin
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  role      Role
  grantedAt DateTime @default(now()) @map("granted_at")
  grantedBy String?  @map("granted_by")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@map("user_roles")
}

// ===== 基礎參照資料 =====

model City {
  id        String   @id @default(cuid())
  name      String   @unique // 例：台北市
  slug      String   @unique // 例：taipei-city
  sortOrder Int      @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  profiles Profile[]
  items    Item[]

  @@map("cities")
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique // 例：食品雜貨
  slug      String   @unique // 例：groceries
  sortOrder Int      @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  items Item[]

  @@map("categories")
}

// ===== 稽核 =====

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?  @map("actor_id")
  action     String // 例：user.role.grant / item.force_remove
  targetType String   @map("target_type") // 例：user / item / report
  targetId   String?  @map("target_id")
  detail     Json?
  sensitive  Boolean  @default(false) // 敏感調閱（私訊、券碼、證據）標記
  createdAt  DateTime @default(now()) @map("created_at")

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId, createdAt])
  @@index([targetType, targetId, createdAt])
  @@map("audit_logs")
}

// ===== 物件儲存（MinIO object key 登錄） =====

enum StorageKind {
  item_image_thumb
  item_image_medium
  report_attachment
  appeal_attachment
  support_attachment
  export_package
}

enum StorageStatus {
  pending // 已上傳但尚未被任何實體引用
  linked // 已被實體引用
  deleted // 已從 MinIO 刪除（保留紀錄）
}

model StorageObject {
  id         String        @id @default(cuid())
  objectKey  String        @unique @map("object_key")
  kind       StorageKind
  status     StorageStatus @default(pending)
  mimeType   String        @map("mime_type")
  sizeBytes  Int           @map("size_bytes")
  width      Int?
  height     Int?
  uploaderId String?       @map("uploader_id")
  createdAt  DateTime      @default(now()) @map("created_at")
  linkedAt   DateTime?     @map("linked_at")
  deletedAt  DateTime?     @map("deleted_at")

  uploader User? @relation(fields: [uploaderId], references: [id], onDelete: SetNull)

  itemImagesAsThumb  ItemImage[] @relation("ItemImageThumb")
  itemImagesAsMedium ItemImage[] @relation("ItemImageMedium")

  @@index([status, createdAt]) // 孤兒檔清理 job 用
  @@index([uploaderId, createdAt])
  @@map("storage_objects")
}

// ===== M1 核心共享主迴路（master-plan.md §6、§11.1）=====

enum ItemStatus {
  draft
  pending_review // M2 REQUIRE_REVIEW flag 開啟時使用，M1 一律略過此態
  published
  reserved
  handover_pending
  completed
  expired // M3 到期 job 使用
  removed_by_user
  removed_by_moderator
}

model Item {
  id          String     @id @default(cuid())
  ownerId     String     @map("owner_id")
  title       String
  description String
  categoryId  String     @map("category_id")
  cityId      String     @map("city_id")
  status      ItemStatus @default(draft)
  publishedAt DateTime?  @map("published_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  owner    User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])
  city     City     @relation(fields: [cityId], references: [id])

  images             ItemImage[]
  statusLogs         ItemStatusLog[]
  claimComments      ClaimComment[]
  directShares       DirectShare[]
  handoverRecord     HandoverRecord?
  thanksMessages     ThanksMessage[]
  contributionEvents ContributionEvent[]
  conversation       Conversation?

  @@index([status, cityId, categoryId, createdAt])
  @@index([status, ownerId, createdAt])
  @@map("items")
}

model ItemImage {
  id             String   @id @default(cuid())
  itemId         String   @map("item_id")
  thumbObjectId  String   @map("thumb_object_id")
  mediumObjectId String   @map("medium_object_id")
  sortOrder      Int      @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")

  item         Item          @relation(fields: [itemId], references: [id], onDelete: Cascade)
  thumbObject  StorageObject @relation("ItemImageThumb", fields: [thumbObjectId], references: [id])
  mediumObject StorageObject @relation("ItemImageMedium", fields: [mediumObjectId], references: [id])

  @@unique([itemId, sortOrder])
  @@index([thumbObjectId]) // 孤兒檔清理 job 刪 StorageObject 時的外鍵檢查用，避免全表掃描
  @@index([mediumObjectId])
  @@map("item_images")
}

model ItemStatusLog {
  id         String      @id @default(cuid())
  itemId     String      @map("item_id")
  fromStatus ItemStatus? @map("from_status")
  toStatus   ItemStatus  @map("to_status")
  actorId    String?     @map("actor_id")
  reason     String?
  createdAt  DateTime    @default(now()) @map("created_at")

  item  Item  @relation(fields: [itemId], references: [id], onDelete: Cascade)
  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([itemId, createdAt])
  @@map("item_status_logs")
}

enum ClaimStatus {
  pending
  accepted
  declined
}

model ClaimComment {
  id        String      @id @default(cuid())
  itemId    String      @map("item_id")
  userId    String      @map("user_id")
  message   String
  status    ClaimStatus @default(pending)
  createdAt DateTime    @default(now()) @map("created_at")

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([itemId, userId])
  @@index([itemId, status, createdAt])
  @@index([userId]) // 「我索取的物品」查詢用；unique(itemId, userId) 的複合索引不能拿來單獨查 userId
  @@map("claim_comments")
}

enum DirectShareStatus {
  pending
  accepted
  declined
  expired
}

model DirectShare {
  id          String            @id @default(cuid())
  itemId      String            @map("item_id")
  receiverId  String            @map("receiver_id")
  status      DirectShareStatus @default(pending)
  respondedAt DateTime?         @map("responded_at")
  expiresAt   DateTime          @map("expires_at")
  createdAt   DateTime          @default(now()) @map("created_at")

  item     Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  receiver User @relation(fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([receiverId, status, createdAt])
  @@map("direct_shares")
}

enum HandoverStatus {
  pending
  completed
  no_show
}

model HandoverRecord {
  id                  String         @id @default(cuid())
  itemId              String         @unique @map("item_id")
  receiverId          String         @map("receiver_id")
  status              HandoverStatus @default(pending)
  ownerConfirmedAt    DateTime?      @map("owner_confirmed_at")
  receiverConfirmedAt DateTime?      @map("receiver_confirmed_at")
  completedAt         DateTime?      @map("completed_at")
  createdAt           DateTime       @default(now()) @map("created_at")

  item     Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  receiver User @relation(fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([receiverId]) // 接手者查看「交接中/已完成」列表用
  @@map("handover_records")
}

model ThanksMessage {
  id         String   @id @default(cuid())
  itemId     String   @unique @map("item_id")
  fromUserId String   @map("from_user_id")
  toUserId   String   @map("to_user_id")
  message    String
  createdAt  DateTime @default(now()) @map("created_at")

  item     Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  fromUser User @relation("ThanksSent", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("ThanksReceived", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([toUserId, createdAt])
  @@map("thanks_messages")
}

enum ContributionType {
  share_completed
  receive_completed
  no_show
}

model ContributionEvent {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  itemId    String?          @map("item_id")
  type      ContributionType
  points    Int
  createdAt DateTime         @default(now()) @map("created_at")

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  item Item? @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@map("contribution_events")
}

enum NotificationType {
  new_comment
  claim_accepted
  direct_share_received
  handover_message
  completion_confirmed
}

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  type      NotificationType
  payload   Json
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@map("notifications")
}

model Conversation {
  id        String   @id @default(cuid())
  itemId    String   @unique @map("item_id")
  createdAt DateTime @default(now()) @map("created_at")

  item     Item                 @relation(fields: [itemId], references: [id], onDelete: Cascade)
  members  ConversationMember[]
  messages Message[]

  @@map("conversations")
}

model ConversationMember {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  userId         String   @map("user_id")
  joinedAt       DateTime @default(now()) @map("joined_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId]) // 收件夾「我的所有對話」查詢用；複合索引以 conversationId 為前導欄，查 userId 用不到
  @@map("conversation_members")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  senderId       String   @map("sender_id")
  body           String
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}
