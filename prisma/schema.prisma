// ShareGood M0 schema — 表清單見 docs/plan/master-plan.md §5 與 §11.1
// 慣例：model PascalCase 單數、DB 表 snake_case 複數（@@map）、欄位 camelCase（@map 成 snake_case）

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // 連線字串在 prisma.config.ts（Prisma 7 起 url 不放 schema）
}

// ===== Auth.js（@auth/prisma-adapter 標準模型） =====

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  deletedAt     DateTime? @map("deleted_at") // M7：帳號刪除去識別化執行時間；User 列本身永不真的
  // DELETE（見 master-plan.md §7a 交付內容 3 設計決策），非 null 代表已去識別化
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts       Account[]
  sessions       Session[]
  profile        Profile?
  roles          UserRole[]
  auditLogs      AuditLog[]      @relation("AuditActor")
  storageObjects StorageObject[]

  items                   Item[]
  itemStatusLogsActed     ItemStatusLog[]
  claimComments           ClaimComment[]
  directSharesReceived    DirectShare[]
  handoverRecords         HandoverRecord[]
  thanksSent              ThanksMessage[]      @relation("ThanksSent")
  thanksReceived          ThanksMessage[]      @relation("ThanksReceived")
  contributionEvents      ContributionEvent[]
  notifications           Notification[]
  conversationMemberships ConversationMember[]
  messagesSent            Message[]

  // M2 治理底線
  reportsSubmitted       Report[]             @relation("ReportReporter")
  reportsHandled         Report[]             @relation("ReportHandler")
  restrictions           UserRestriction[]    @relation("UserRestrictionTarget")
  restrictionsCreated    UserRestriction[]    @relation("UserRestrictionCreatedBy")
  restrictionsLifted     UserRestriction[]    @relation("UserRestrictionLiftedBy")
  itemRemovalsActed      ItemRemoval[]        @relation("ItemRemovalModerator")
  supportTickets         SupportTicket[]      @relation("SupportTicketUser")
  supportTicketsAssigned SupportTicket[]      @relation("SupportTicketAssignee")
  supportTicketEvents    SupportTicketEvent[] @relation("SupportTicketEventActor")
  appeals                Appeal[]             @relation("AppealUser")
  appealsReviewed        Appeal[]             @relation("AppealReviewer")

  // M3 到期與優惠券
  couponRevealLogs CouponRevealLog[]

  // M4 通知強化
  notificationPreferences NotificationPreference[]
  telegramAccount         TelegramAccount?
  telegramLinkTokens      TelegramLinkToken[]

  // M5 抽籤
  lotteriesCreated Lottery[]
  lotteryEntries   LotteryEntry[]
  lotteryResults   LotteryResult[]
  lotteryAuditLogs LotteryAuditLog[]

  // M6 訂閱通知＋Web Push
  subscriptions          UserSubscription[]
  webPushSubscriptions   WebPushSubscription[]
  subscriptionDigestJobs SubscriptionDigestJob[]

  // M7 資料權利與法務
  privacyRequests                        PrivacyRequest[]                @relation("PrivacyRequestUser")
  privacyRequestsProcessed               PrivacyRequest[]                @relation("PrivacyRequestProcessor")
  dataExports                            DataExport[]
  dataRetentionPolicyUpdates             DataRetentionPolicy[]
  lawEnforcementRequestsSubmitted        LawEnforcementRequest[]         @relation("LawEnforcementRequestSubmitter")
  lawEnforcementRequestsApproved         LawEnforcementRequest[]         @relation("LawEnforcementRequestApprover")
  lawEnforcementRequestDocumentsUploaded LawEnforcementRequestDocument[]
  lawEnforcementRequestEvents            LawEnforcementRequestEvent[]
  legalHoldsCreated                      LegalHold[]                     @relation("LegalHoldCreator")
  legalHoldsReleased                     LegalHold[]                     @relation("LegalHoldReleaser")
  legalHoldEvents                        LegalHoldEvent[]

  // M9 好康資訊與券票點強化（schema 地基）
  dealInfosSubmitted DealInfo[]
  dealInfoReports    DealInfoReport[]
  couponUsageReports CouponUsageReport[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ===== 個人資料與權限 =====

model Profile {
  userId    String   @id @map("user_id")
  nickname  String
  cityId    String?  @map("city_id")
  bio       String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  city City? @relation(fields: [cityId], references: [id])

  @@map("profiles")
}

enum Role {
  user
  moderator
  admin
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  role      Role
  grantedAt DateTime @default(now()) @map("granted_at")
  grantedBy String?  @map("granted_by")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@map("user_roles")
}

// ===== 基礎參照資料 =====

model City {
  id        String   @id @default(cuid())
  name      String   @unique // 例：台北市
  slug      String   @unique // 例：taipei-city
  sortOrder Int      @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  profiles Profile[]
  items    Item[]

  // M6 訂閱通知：訂閱可依縣市篩選
  subscriptionCities SubscriptionCity[]

  // M9 好康資訊：DealInfo 縣市篩選
  dealInfoCities DealInfoCity[]

  @@map("cities")
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique // 例：食品雜貨
  slug      String   @unique // 例：groceries
  sortOrder Int      @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  items Item[]

  // M6 訂閱通知：訂閱可依分類篩選
  subscriptionCategories SubscriptionCategory[]

  @@map("categories")
}

// ===== 稽核 =====

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?  @map("actor_id")
  action     String // 例：user.role.grant / item.force_remove
  targetType String   @map("target_type") // 例：user / item / report
  targetId   String?  @map("target_id")
  detail     Json?
  sensitive  Boolean  @default(false) // 敏感調閱（私訊、券碼、證據）標記
  createdAt  DateTime @default(now()) @map("created_at")

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId, createdAt])
  @@index([targetType, targetId, createdAt])
  @@map("audit_logs")
}

// ===== 物件儲存（MinIO object key 登錄） =====

enum StorageKind {
  item_image_thumb
  item_image_medium
  report_attachment
  appeal_attachment
  support_attachment
  export_package
  law_enforcement_document // M7：警方/檢調調閱來文掃描檔
  law_enforcement_export // M7：依調閱範圍產生的匯出包
}

enum StorageStatus {
  pending // 已上傳但尚未被任何實體引用
  linked // 已被實體引用
  deleted // 已從 MinIO 刪除（保留紀錄）
}

model StorageObject {
  id         String        @id @default(cuid())
  objectKey  String        @unique @map("object_key")
  kind       StorageKind
  status     StorageStatus @default(pending)
  mimeType   String        @map("mime_type")
  sizeBytes  Int           @map("size_bytes")
  width      Int?
  height     Int?
  uploaderId String?       @map("uploader_id")
  createdAt  DateTime      @default(now()) @map("created_at")
  linkedAt   DateTime?     @map("linked_at")
  deletedAt  DateTime?     @map("deleted_at")

  uploader User? @relation(fields: [uploaderId], references: [id], onDelete: SetNull)

  itemImagesAsThumb  ItemImage[] @relation("ItemImageThumb")
  itemImagesAsMedium ItemImage[] @relation("ItemImageMedium")

  reportEvidence           ReportEvidence[]
  supportTicketAttachments SupportTicketAttachment[]
  appealEvidence           AppealEvidence[]

  // M7 資料權利與法務
  dataExports                    DataExport[]
  lawEnforcementRequestDocuments LawEnforcementRequestDocument[]
  lawEnforcementExports          LawEnforcementExport[]

  @@index([status, createdAt]) // 孤兒檔清理 job 用
  @@index([uploaderId, createdAt])
  @@map("storage_objects")
}

// ===== M1 核心共享主迴路（master-plan.md §6、§11.1）=====

enum ItemStatus {
  draft
  pending_review // M2 REQUIRE_REVIEW flag 開啟時使用，M1 一律略過此態
  published
  reserved
  handover_pending
  completed
  expired // M3 到期 job 使用
  removed_by_user
  removed_by_moderator
}

model Item {
  id          String     @id @default(cuid())
  ownerId     String     @map("owner_id")
  title       String
  description String
  categoryId  String     @map("category_id")
  cityId      String     @map("city_id")
  status      ItemStatus @default(draft)
  publishedAt DateTime?  @map("published_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  owner    User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])
  city     City     @relation(fields: [cityId], references: [id])

  images             ItemImage[]
  statusLogs         ItemStatusLog[]
  claimComments      ClaimComment[]
  directShares       DirectShare[]
  handoverRecord     HandoverRecord?
  thanksMessages     ThanksMessage[]
  contributionEvents ContributionEvent[]
  conversation       Conversation?

  // M2 治理底線
  reports      Report[]
  itemRemovals ItemRemoval[]

  // M3 到期與優惠券（expiresAt 為通用到期時間戳，優惠券／即期食品共用同一欄位，
  // 由到期 job 統一處理，見 master-plan.md §8）
  expiresAt      DateTime?           @map("expires_at")
  couponDetail   CouponDetail?
  expirationLogs ItemExpirationLog[]

  // M5 抽籤（一物品終身最多一次抽籤，見 Lottery.itemId @unique）
  lottery Lottery?

  // M6 訂閱通知：比對命中紀錄
  subscriptionMatches SubscriptionMatch[]

  // M9 券類強化：使用結果回報（可用／已失效）
  couponUsageReports CouponUsageReport[]

  // M9 票券／點數類型（沿用「共通設計決策」：category slug 判別，不加 items.type 欄位；
  // 效期沿用既有 expiresAt，兩張 detail 表皆不設自己的效期欄位）
  ticketDetail TicketDetail?
  pointDetail  PointDetail?

  @@index([status, cityId, categoryId, createdAt])
  @@index([status, ownerId, createdAt])
  @@index([status, expiresAt])
  @@map("items")
}

model ItemImage {
  id             String   @id @default(cuid())
  itemId         String   @map("item_id")
  thumbObjectId  String   @map("thumb_object_id")
  mediumObjectId String   @map("medium_object_id")
  sortOrder      Int      @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")

  item         Item          @relation(fields: [itemId], references: [id], onDelete: Cascade)
  thumbObject  StorageObject @relation("ItemImageThumb", fields: [thumbObjectId], references: [id])
  mediumObject StorageObject @relation("ItemImageMedium", fields: [mediumObjectId], references: [id])

  @@unique([itemId, sortOrder])
  @@index([thumbObjectId]) // 孤兒檔清理 job 刪 StorageObject 時的外鍵檢查用，避免全表掃描
  @@index([mediumObjectId])
  @@map("item_images")
}

model ItemStatusLog {
  id         String      @id @default(cuid())
  itemId     String      @map("item_id")
  fromStatus ItemStatus? @map("from_status")
  toStatus   ItemStatus  @map("to_status")
  actorId    String?     @map("actor_id")
  reason     String?
  createdAt  DateTime    @default(now()) @map("created_at")

  item  Item  @relation(fields: [itemId], references: [id], onDelete: Cascade)
  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([itemId, createdAt])
  @@map("item_status_logs")
}

enum ClaimStatus {
  pending
  accepted
  declined
}

model ClaimComment {
  id        String      @id @default(cuid())
  itemId    String      @map("item_id")
  userId    String      @map("user_id")
  message   String
  status    ClaimStatus @default(pending)
  createdAt DateTime    @default(now()) @map("created_at")

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  reports Report[]

  @@unique([itemId, userId])
  @@index([itemId, status, createdAt])
  @@index([userId]) // 「我索取的物品」查詢用；unique(itemId, userId) 的複合索引不能拿來單獨查 userId
  @@map("claim_comments")
}

enum DirectShareStatus {
  pending
  accepted
  declined
  expired
}

model DirectShare {
  id          String            @id @default(cuid())
  itemId      String            @map("item_id")
  receiverId  String            @map("receiver_id")
  status      DirectShareStatus @default(pending)
  respondedAt DateTime?         @map("responded_at")
  expiresAt   DateTime          @map("expires_at")
  createdAt   DateTime          @default(now()) @map("created_at")

  item     Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  receiver User @relation(fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([receiverId, status, createdAt])
  @@map("direct_shares")
}

enum HandoverStatus {
  pending
  completed
  no_show
}

model HandoverRecord {
  id                  String         @id @default(cuid())
  itemId              String         @unique @map("item_id")
  receiverId          String         @map("receiver_id")
  status              HandoverStatus @default(pending)
  ownerConfirmedAt    DateTime?      @map("owner_confirmed_at")
  receiverConfirmedAt DateTime?      @map("receiver_confirmed_at")
  completedAt         DateTime?      @map("completed_at")
  createdAt           DateTime       @default(now()) @map("created_at")

  item     Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  receiver User @relation(fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([receiverId]) // 接手者查看「交接中/已完成」列表用
  @@map("handover_records")
}

model ThanksMessage {
  id         String   @id @default(cuid())
  itemId     String   @unique @map("item_id")
  fromUserId String   @map("from_user_id")
  toUserId   String   @map("to_user_id")
  message    String
  createdAt  DateTime @default(now()) @map("created_at")

  item     Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  fromUser User @relation("ThanksSent", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("ThanksReceived", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([toUserId, createdAt])
  @@map("thanks_messages")
}

enum ContributionType {
  share_completed
  receive_completed
  no_show
}

model ContributionEvent {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  itemId    String?          @map("item_id")
  type      ContributionType
  points    Int
  createdAt DateTime         @default(now()) @map("created_at")

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  item Item? @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@map("contribution_events")
}

enum NotificationType {
  new_comment
  claim_accepted
  direct_share_received
  handover_message
  completion_confirmed
}

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  type      NotificationType
  payload   Json
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  deliveries NotificationDelivery[]

  @@index([userId, readAt, createdAt])
  @@map("notifications")
}

model Conversation {
  id        String   @id @default(cuid())
  itemId    String   @unique @map("item_id")
  createdAt DateTime @default(now()) @map("created_at")

  item     Item                 @relation(fields: [itemId], references: [id], onDelete: Cascade)
  members  ConversationMember[]
  messages Message[]

  @@map("conversations")
}

model ConversationMember {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  userId         String   @map("user_id")
  joinedAt       DateTime @default(now()) @map("joined_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId]) // 收件夾「我的所有對話」查詢用；複合索引以 conversationId 為前導欄，查 userId 用不到
  @@map("conversation_members")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  senderId       String   @map("sender_id")
  body           String
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  reports Report[]

  @@index([conversationId, createdAt])
  @@map("messages")
}

// ===== M2 治理底線（master-plan.md §7、§11.1）=====
// Wave 0 schema 地基：本節只建表與索引，不含任何 API/業務邏輯（那些留給 M2 各 wave 的功能 agent）。

enum ReportCategory {
  fraud // 詐騙
  private_payment // 私下收費
  prohibited_item // 違禁品
  food_safety // 食品疑慮
  harassment // 騷擾
  other
}

enum ReportStatus {
  submitted
  triaged
  in_progress
  resolved
  rejected
  closed
}

// 檢舉目標可能是物品／留言／私訊三者之一：用多個可為 null 的外鍵欄位表達，
// 沿用本專案已有的「optional FK」風格（參考 ContributionEvent.itemId），
// 不用多型關聯（polymorphic association），實作與查詢都更直接。
model Report {
  id             String         @id @default(cuid())
  reporterId     String         @map("reporter_id")
  itemId         String?        @map("item_id")
  claimCommentId String?        @map("claim_comment_id")
  messageId      String?        @map("message_id")
  category       ReportCategory
  status         ReportStatus   @default(submitted)
  description    String
  handledBy      String?        @map("handled_by")
  resolutionNote String?        @map("resolution_note")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  resolvedAt     DateTime?      @map("resolved_at")

  reporter     User          @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  item         Item?         @relation(fields: [itemId], references: [id], onDelete: Cascade)
  claimComment ClaimComment? @relation(fields: [claimCommentId], references: [id], onDelete: Cascade)
  message      Message?      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  handler      User?         @relation("ReportHandler", fields: [handledBy], references: [id], onDelete: SetNull)

  evidence ReportEvidence[]

  @@index([status, createdAt])
  @@index([reporterId, createdAt])
  @@index([itemId])
  @@index([claimCommentId])
  @@index([messageId])
  @@map("reports")
}

model ReportEvidence {
  id              String   @id @default(cuid())
  reportId        String   @map("report_id")
  storageObjectId String   @map("storage_object_id")
  sortOrder       Int      @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")

  report        Report        @relation(fields: [reportId], references: [id], onDelete: Cascade)
  storageObject StorageObject @relation(fields: [storageObjectId], references: [id], onDelete: Restrict)

  @@unique([reportId, sortOrder])
  @@index([storageObjectId])
  @@map("report_evidence")
}

// 禁上架/禁留言/禁私訊/全站封鎖，expiresAt 為 null 表示永久
enum RestrictionType {
  no_posting
  no_claiming
  no_messaging
  full_block
}

model UserRestriction {
  id        String          @id @default(cuid())
  userId    String          @map("user_id")
  type      RestrictionType
  reason    String
  expiresAt DateTime?       @map("expires_at") // null = 永久
  createdBy String?         @map("created_by")
  liftedAt  DateTime?       @map("lifted_at") // 提前解除
  liftedBy  String?         @map("lifted_by")
  createdAt DateTime        @default(now()) @map("created_at")

  user          User  @relation("UserRestrictionTarget", fields: [userId], references: [id], onDelete: Cascade)
  createdByUser User? @relation("UserRestrictionCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  liftedByUser  User? @relation("UserRestrictionLiftedBy", fields: [liftedBy], references: [id], onDelete: SetNull)

  appeal Appeal?

  @@index([userId, type])
  @@index([userId, expiresAt])
  @@map("user_restrictions")
}

model ItemRemoval {
  id          String   @id @default(cuid())
  itemId      String   @map("item_id")
  moderatorId String?  @map("moderator_id")
  reason      String
  note        String?
  createdAt   DateTime @default(now()) @map("created_at")

  item      Item  @relation(fields: [itemId], references: [id], onDelete: Cascade)
  moderator User? @relation("ItemRemovalModerator", fields: [moderatorId], references: [id], onDelete: SetNull)

  appeal Appeal?

  @@index([itemId, createdAt])
  @@index([moderatorId, createdAt])
  @@map("item_removals")
}

enum SupportTicketCategory {
  bug
  account
  other
}

enum SupportTicketStatus {
  open
  in_progress
  resolved
  closed
}

model SupportTicket {
  id          String                @id @default(cuid())
  userId      String                @map("user_id")
  category    SupportTicketCategory
  subject     String
  description String
  status      SupportTicketStatus   @default(open)
  assignedTo  String?               @map("assigned_to")
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")

  user     User  @relation("SupportTicketUser", fields: [userId], references: [id], onDelete: Cascade)
  assignee User? @relation("SupportTicketAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)

  events      SupportTicketEvent[]
  attachments SupportTicketAttachment[]

  @@index([status, createdAt])
  @@index([userId, createdAt])
  @@map("support_tickets")
}

// 沿用 ItemStatusLog 的既有風格：fromStatus/toStatus 皆可為 null 代表純留言，
// 不另外新增事件種類 enum。
model SupportTicketEvent {
  id         String               @id @default(cuid())
  ticketId   String               @map("ticket_id")
  actorId    String?              @map("actor_id")
  fromStatus SupportTicketStatus? @map("from_status")
  toStatus   SupportTicketStatus? @map("to_status")
  message    String?
  createdAt  DateTime             @default(now()) @map("created_at")

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actor  User?         @relation("SupportTicketEventActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([ticketId, createdAt])
  @@map("support_ticket_events")
}

model SupportTicketAttachment {
  id              String   @id @default(cuid())
  ticketId        String   @map("ticket_id")
  storageObjectId String   @map("storage_object_id")
  sortOrder       Int      @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")

  ticket        SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  storageObject StorageObject @relation(fields: [storageObjectId], references: [id], onDelete: Restrict)

  @@unique([ticketId, sortOrder])
  @@index([storageObjectId])
  @@map("support_ticket_attachments")
}

enum AppealStatus {
  pending
  approved
  rejected
}

// 被下架/被限制者可申訴一次：userRestrictionId／itemRemovalId 各自加 @unique，
// Postgres 的 unique index 允許多筆 NULL 但非 NULL 值不可重複，剛好表達
// 「每個限制/下架事件最多一次申訴」。
model Appeal {
  id                String       @id @default(cuid())
  userId            String       @map("user_id")
  userRestrictionId String?      @unique @map("user_restriction_id")
  itemRemovalId     String?      @unique @map("item_removal_id")
  reason            String
  status            AppealStatus @default(pending)
  reviewedBy        String?      @map("reviewed_by")
  reviewNote        String?      @map("review_note")
  createdAt         DateTime     @default(now()) @map("created_at")
  reviewedAt        DateTime?    @map("reviewed_at")

  user            User             @relation("AppealUser", fields: [userId], references: [id], onDelete: Cascade)
  userRestriction UserRestriction? @relation(fields: [userRestrictionId], references: [id], onDelete: Cascade)
  itemRemoval     ItemRemoval?     @relation(fields: [itemRemovalId], references: [id], onDelete: Cascade)
  reviewer        User?            @relation("AppealReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)

  evidence AppealEvidence[]

  @@index([status, createdAt])
  @@index([userId, createdAt])
  @@map("appeals")
}

model AppealEvidence {
  id              String   @id @default(cuid())
  appealId        String   @map("appeal_id")
  storageObjectId String   @map("storage_object_id")
  sortOrder       Int      @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")

  appeal        Appeal        @relation(fields: [appealId], references: [id], onDelete: Cascade)
  storageObject StorageObject @relation(fields: [storageObjectId], references: [id], onDelete: Restrict)

  @@unique([appealId, sortOrder])
  @@index([storageObjectId])
  @@map("appeal_evidence")
}

// 關鍵字黑名單：攔上架標題與描述。keyword 存正規化後的字串（小寫、去空白，
// 正規化邏輯留給寫 route 的 agent），isActive 讓後台可以軟停用而不必刪紀錄
// （沿用 Category.isActive 的既有風格）。
model KeywordBlocklist {
  id        String   @id @default(cuid())
  keyword   String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("keyword_blocklist")
}

// MVP 起步：全站開關，不做百分比灰度或多環境。REQUIRE_REVIEW 等旗標即用此表。
model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  enabled     Boolean  @default(false)
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("feature_flags")
}

// ===== M3 到期與優惠券（master-plan.md §8、§11.1）=====

// 面額/店家為描述性文字而非金流欄位（專案不做金流）；到期日沿用 Item.expiresAt，
// 不重複存一份避免兩處日期不同步。
model CouponDetail {
  id           String   @id @default(cuid())
  itemId       String   @unique @map("item_id")
  faceValue    String   @map("face_value") // 例：「$100 折價」「買一送一」
  merchantName String   @map("merchant_name") // 適用店家
  notes        String? // 使用限制等備註
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  item   Item          @relation(fields: [itemId], references: [id], onDelete: Cascade)
  secret CouponSecret?

  @@map("coupon_details")
}

// 券碼密文與明文欄位刻意分兩張表：加密資料獨立成表，方便未來做欄位級的存取控制
// （例如只有特定 API 路徑能查詢 coupon_secrets，一般查詢 coupon_details 完全碰不到密文）。
model CouponSecret {
  id             String   @id @default(cuid())
  couponDetailId String   @unique @map("coupon_detail_id")
  ciphertext     String // AES-256-GCM 加密後券碼
  iv             String // 初始向量（base64）
  authTag        String   @map("auth_tag") // GCM 認證標籤（base64）
  createdAt      DateTime @default(now()) @map("created_at")

  couponDetail CouponDetail      @relation(fields: [couponDetailId], references: [id], onDelete: Cascade)
  revealLogs   CouponRevealLog[]

  @@map("coupon_secrets")
}

model CouponRevealLog {
  id             String   @id @default(cuid())
  couponSecretId String   @map("coupon_secret_id")
  revealedBy     String?  @map("revealed_by")
  revealedAt     DateTime @default(now()) @map("revealed_at")

  couponSecret CouponSecret @relation(fields: [couponSecretId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [revealedBy], references: [id], onDelete: SetNull)

  @@index([couponSecretId, revealedAt])
  @@map("coupon_reveal_logs")
}

// 到期 job 的 idempotent 保護：unique(itemId, action) 讓「過期轉態」與「即將到期提醒」
// 各自最多發生一次，job 重複觸發不會重複通知。
enum ItemExpirationAction {
  expired
  reminder_sent
}

model ItemExpirationLog {
  id        String               @id @default(cuid())
  itemId    String               @map("item_id")
  action    ItemExpirationAction
  createdAt DateTime             @default(now()) @map("created_at")

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, action])
  @@map("item_expiration_logs")
}

// 系統排程 job 的登記表＋每次執行紀錄，經典模式。job lock（防同一 job 併發執行）
// 留給之後寫 route 邏輯的 agent 處理（例如 transaction + SystemJobRun 判斷是否有
// status='running' 的紀錄），schema 層不做（沒有 partial unique index 這類額外約束）。
enum SystemJobRunStatus {
  running
  success
  failed
}

model SystemJob {
  id          String   @id @default(cuid())
  key         String   @unique // 例："item_expiration"
  description String?
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  runs SystemJobRun[]

  @@map("system_jobs")
}

model SystemJobRun {
  id         String             @id @default(cuid())
  jobId      String             @map("job_id")
  status     SystemJobRunStatus @default(running)
  startedAt  DateTime           @default(now()) @map("started_at")
  finishedAt DateTime?          @map("finished_at")
  detail     Json? // 記錄這次處理了幾筆等統計資訊
  createdAt  DateTime           @default(now()) @map("created_at")

  job SystemJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  // M7：retention 清理 job 每次動手都可回指到觸發它的這次執行紀錄
  dataPurgeLogs DataPurgeLog[]

  @@index([jobId, startedAt])
  @@map("system_job_runs")
}

// ===== M4 通知強化（master-plan.md §9、§11.1）=====

// eventType 用字串 key（不用 enum）：未來新增通知種類（例如到期提醒、檢舉處理結果）
// 不必為了偏好設定再改一次 schema，跟 FeatureFlag 的「DB config」風格一致。
model NotificationPreference {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  eventType       String   @map("event_type") // 例："claim_accepted"、"handover_message"、"expiring_soon"
  inAppEnabled    Boolean  @default(true) @map("in_app_enabled")
  externalEnabled Boolean  @default(false) @map("external_enabled") // 外部通知預設關，關鍵事件由 app 邏輯/seed 設預設值
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventType])
  @@map("notification_preferences")
}

enum NotificationChannel {
  telegram
  web_push // M6 起
}

enum NotificationDeliveryStatus {
  pending
  sent
  failed
}

// 通知重複保護：unique(notificationId, channel) 讓同一則站內通知在同一管道
// 最多只會有一筆外部送達紀錄（delivery idempotency，對照 master-plan §11.3）。
model NotificationDelivery {
  id             String                     @id @default(cuid())
  notificationId String                     @map("notification_id")
  channel        NotificationChannel        @default(telegram)
  status         NotificationDeliveryStatus @default(pending)
  attempts       Int                        @default(0)
  lastError      String?                    @map("last_error")
  lastAttemptAt  DateTime?                  @map("last_attempt_at") // M8：距離上次嘗試（不論成敗）
  // 過了多久，供指數退避重送 job 判斷是否到重試時機（sentAt 語意是「成功送達時間」，
  // 重試中失敗紀錄該欄是 null，故另立此欄，見 master-plan.md §8a 交付內容 6）
  sentAt         DateTime?                  @map("sent_at")
  createdAt      DateTime                   @default(now()) @map("created_at")

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@unique([notificationId, channel])
  @@index([status, createdAt])
  @@map("notification_deliveries")
}

model TelegramAccount {
  id               String    @id @default(cuid())
  userId           String    @unique @map("user_id")
  telegramChatId   String    @unique @map("telegram_chat_id")
  telegramUsername String?   @map("telegram_username")
  isActive         Boolean   @default(true) @map("is_active")
  linkedAt         DateTime  @default(now()) @map("linked_at")
  unlinkedAt       DateTime? @map("unlinked_at") // 失效自動解綁時記錄

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("telegram_accounts")
}

model TelegramLinkToken {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  token      String    @unique
  expiresAt  DateTime  @map("expires_at")
  consumedAt DateTime? @map("consumed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("telegram_link_tokens")
}

// webhook update_id 去重：只存 updateId + processedAt，不存整包 payload（M4 需求明文如此）。
model TelegramUpdate {
  id          String    @id @default(cuid())
  updateId    BigInt    @unique @map("update_id")
  processedAt DateTime? @map("processed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("telegram_updates")
}

// ===== M5 抽籤（master-plan.md §5a、§11.1）=====
// 狀態機設計見規格文件：lotteries.status 是防重複開獎/遞補推進的樂觀鎖本體，
// items.status 完全不新增任何值（見 §5a 交付內容 1、2）。

enum LotteryStatus {
  open
  drawing
  awaiting_confirmation
  completed
  failed_no_entries
  cancelled
}

enum LotteryEntryStatus {
  entered
  cancelled
}

enum LotteryResultStatus {
  pending
  offered
  confirmed
  expired
  declined
}

// 一物品終身最多一次抽籤：itemId @unique（見「不做多輪抽籤」scope guard）。
model Lottery {
  id            String        @id @default(cuid())
  itemId        String        @unique @map("item_id")
  creatorId     String        @map("creator_id") // = 物品 owner_id，冗餘存一份方便查詢
  entryDeadline DateTime      @map("entry_deadline") // 建立後不可修改
  status        LotteryStatus @default(open)
  seed          String? // crypto.randomBytes(32).toString('hex')，開獎當下才寫入
  entrySnapshot Json?         @map("entry_snapshot") // 開獎當下 canonical 排序後的 entry id 陣列
  algoVersion   String?       @map("algo_version") // 例："hmac-sha256-fisher-yates-v1"
  drawnAt       DateTime?     @map("drawn_at")
  currentRank   Int?          @map("current_rank") // 目前正等待確認的順位
  completedAt   DateTime?     @map("completed_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  item    Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  creator User @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  entries   LotteryEntry[]
  results   LotteryResult[]
  auditLogs LotteryAuditLog[]

  @@index([status, entryDeadline]) // 開獎 job 撈到期未開獎的抽籤
  @@map("lotteries")
}

model LotteryEntry {
  id          String             @id @default(cuid())
  lotteryId   String             @map("lottery_id")
  userId      String             @map("user_id")
  status      LotteryEntryStatus @default(entered)
  enteredAt   DateTime           @default(now()) @map("entered_at")
  cancelledAt DateTime?          @map("cancelled_at")

  lottery Lottery @relation(fields: [lotteryId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  results LotteryResult[]

  @@unique([lotteryId, userId])
  @@index([lotteryId, status]) // 開獎時撈 status='entered' 名單
  @@map("lottery_entries")
}

model LotteryResult {
  id              String              @id @default(cuid())
  lotteryId       String              @map("lottery_id")
  entryId         String              @map("entry_id")
  userId          String              @map("user_id") // 冗餘存一份，方便查詢不必 join entries
  rank            Int
  status          LotteryResultStatus @default(pending)
  offeredAt       DateTime?           @map("offered_at")
  confirmDeadline DateTime?           @map("confirm_deadline") // = offeredAt + 48h
  respondedAt     DateTime?           @map("responded_at")
  createdAt       DateTime            @default(now()) @map("created_at")

  lottery Lottery      @relation(fields: [lotteryId], references: [id], onDelete: Cascade)
  entry   LotteryEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([lotteryId, rank])
  @@unique([lotteryId, entryId])
  @@index([status, confirmDeadline]) // job 撈到期未確認的候選人
  @@map("lottery_results")
}

// append-only 稽核紀錄；actorId 為 null 代表系統排程觸發。依 createdAt 排序讀出應能還原
// 完整時間序（誰在何時報名/取消、何時開獎、每次遞補的前因後果、最終誰確認）。
model LotteryAuditLog {
  id        String   @id @default(cuid())
  lotteryId String   @map("lottery_id")
  action    String // entry_created / entry_cancelled / draw_started / draw_completed /
  // draw_failed_no_entries / rank_offered / rank_confirmed / rank_expired /
  // rank_declined / lottery_cancelled / item_reserved
  actorId   String?  @map("actor_id")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  lottery Lottery @relation(fields: [lotteryId], references: [id], onDelete: Cascade)
  actor   User?   @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([lotteryId, createdAt])
  @@map("lottery_audit_logs")
}

// ===== M6 訂閱通知＋Web Push（master-plan.md §6a、§11.1）=====
// 訂閱（篩選條件）與 M4 NotificationPreference（管道與開關）是兩層獨立閘門，分工見
// §6a 交付內容 2；本節不修改 NotificationPreference 既有語意（eventType 是自由字串，
// 新增 subscription_match/subscription_digest 兩個事件類型不需要 migration）。
// NotificationChannel 已於上方新增 web_push 值。

model UserSubscription {
  id                 String   @id @default(cuid())
  userId             String   @map("user_id")
  label              String? // 使用者自訂名稱，純顯示用，不參與比對邏輯
  immediateEnabled   Boolean  @default(false) @map("immediate_enabled")
  dailyDigestEnabled Boolean  @default(true) @map("daily_digest_enabled")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  keywords   SubscriptionKeyword[]
  categories SubscriptionCategory[]
  cities     SubscriptionCity[]
  matches    SubscriptionMatch[]

  @@index([userId])
  @@map("user_subscriptions")
}

model SubscriptionKeyword {
  id                String   @id @default(cuid())
  subscriptionId    String   @map("subscription_id")
  keyword           String // 使用者原始輸入，保留給 UI 顯示（可能是全形/大寫）
  normalizedKeyword String   @map("normalized_keyword") // 正規化後的比對用字串
  createdAt         DateTime @default(now()) @map("created_at")

  subscription UserSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, normalizedKeyword])
  @@index([subscriptionId])
  @@index([normalizedKeyword]) // 依關鍵字反查/除錯/濫用調查用（非熱路徑比對本身在用，見規格）
  @@map("subscription_keywords")
}

model SubscriptionCategory {
  id             String   @id @default(cuid())
  subscriptionId String   @map("subscription_id")
  categoryId     String   @map("category_id")
  createdAt      DateTime @default(now()) @map("created_at")

  subscription UserSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  category     Category         @relation(fields: [categoryId], references: [id])

  @@unique([subscriptionId, categoryId])
  @@map("subscription_categories")
}

model SubscriptionCity {
  id             String   @id @default(cuid())
  subscriptionId String   @map("subscription_id")
  cityId         String   @map("city_id")
  createdAt      DateTime @default(now()) @map("created_at")

  subscription UserSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  city         City             @relation(fields: [cityId], references: [id])

  @@unique([subscriptionId, cityId])
  @@map("subscription_cities")
}

// 「同物品同訂閱只通知一次」的 idempotency 核心：unique(subscriptionId, itemId)。
model SubscriptionMatch {
  id             String    @id @default(cuid())
  subscriptionId String    @map("subscription_id")
  itemId         String    @map("item_id")
  matchedAt      DateTime  @default(now()) @map("matched_at")
  notifiedAt     DateTime? @map("notified_at") // null = 已比對成功但尚未通知，等每日摘要 job 撿走
  notifiedVia    String?   @map("notified_via") // 'immediate' | 'digest'
  digestJobId    String?   @map("digest_job_id")

  subscription UserSubscription       @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  item         Item                   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  digestJob    SubscriptionDigestJob? @relation(fields: [digestJobId], references: [id], onDelete: SetNull)

  @@unique([subscriptionId, itemId])
  @@index([notifiedAt]) // 每日摘要 job 撈 notifiedAt IS NULL 用
  @@map("subscription_matches")
}

// 每人每個台北曆日最多一筆：這是每日摘要的「派送紀錄」，排程觸發沿用 M3 system_jobs。
model SubscriptionDigestJob {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  digestDate DateTime  @map("digest_date") @db.Date // Asia/Taipei 曆日（不是 UTC 日期）
  status     String // 'pending' | 'sent' | 'skipped_empty' | 'failed'
  itemCount  Int       @default(0) @map("item_count")
  sentAt     DateTime? @map("sent_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user    User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  matches SubscriptionMatch[]

  @@unique([userId, digestDate])
  @@map("subscription_digest_jobs")
}

// 欄位對應瀏覽器 Push API 標準的 PushSubscription 物件（endpoint／keys.p256dh／keys.auth），
// 查證來源：MDN PushSubscription、web-push npm 套件文件。同一使用者可有多筆（多裝置/多瀏覽器）。
model WebPushSubscription {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  endpoint      String    @unique // push service 的推播端點 URL，瀏覽器端唯一
  p256dhKey     String    @map("p256dh_key") // PushSubscription.keys.p256dh
  authKey       String    @map("auth_key") // PushSubscription.keys.auth
  userAgent     String?   @map("user_agent") // 除錯與清理用，非必要
  isActive      Boolean   @default(true) @map("is_active")
  failureCount  Int       @default(0) @map("failure_count")
  lastSuccessAt DateTime? @map("last_success_at")
  lastFailureAt DateTime? @map("last_failure_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  deactivatedAt DateTime? @map("deactivated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("web_push_subscriptions")
}

// ===== M7 資料權利與法務（master-plan.md §7a、§11.1）=====
// ⚠️ 法律免責聲明：本節資料保留期限／去識別化範圍／legal hold 認定／警方調閱流程
// （尤其「是否通知當事人」）均為技術實作參考，不構成法律意見、不能替代律師意見；
// 正式營運前需台灣律師與平台法務審閱（見 §7a 節首與節尾聲明）。

enum PrivacyRequestType {
  data_export
  account_deletion
}

enum PrivacyRequestStatus {
  submitted
  cooling_off
  confirmed
  processing
  completed
  cancelled
  rejected
}

enum DataExportStatus {
  pending
  processing
  ready
  expired
  failed
}

enum RetentionAction {
  purge
  anonymize
  downgrade
  archive
}

enum LawEnforcementRequestStatus {
  submitted
  legal_review
  approved
  rejected
  fulfilled
  closed
}

enum LegalHoldStatus {
  active
  released
}

// 匯出與刪除共用一張表，用 type 區分；關聯方向刻意設計成「特定表指回通用表」
// （DataExport.privacyRequestId → PrivacyRequest.id 而非反過來），理由見規格文件
// §7a 交付內容 1：先建 PrivacyRequest 拿到 id，再建 DataExport 帶入這個 id，順序自然。
model PrivacyRequest {
  id              String               @id @default(cuid())
  userId          String               @map("user_id")
  type            PrivacyRequestType
  status          PrivacyRequestStatus @default(submitted)
  reason          String?
  coolingOffUntil DateTime?            @map("cooling_off_until") // 僅 account_deletion 使用
  processedBy     String?              @map("processed_by") // 系統自動執行為 null；人工介入才記錄 admin
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")
  completedAt     DateTime?            @map("completed_at")

  user       User        @relation("PrivacyRequestUser", fields: [userId], references: [id], onDelete: Cascade)
  processor  User?       @relation("PrivacyRequestProcessor", fields: [processedBy], references: [id], onDelete: SetNull)
  dataExport DataExport?

  @@index([userId, type, createdAt])
  @@index([status, coolingOffUntil]) // 冷卻期到期掃描用
  @@map("privacy_requests")
}

model DataExport {
  id               String           @id @default(cuid())
  userId           String           @map("user_id")
  privacyRequestId String           @unique @map("privacy_request_id") // 一個請求最多一筆匯出細節
  status           DataExportStatus @default(pending)
  storageObjectId  String?          @map("storage_object_id") // 打包完成才寫入，kind=export_package
  requestedAt      DateTime         @default(now()) @map("requested_at")
  readyAt          DateTime?        @map("ready_at")
  expiresAt        DateTime?        @map("expires_at") // = readyAt + 7 天
  downloadCount    Int              @default(0) @map("download_count") // 純觀察用，不限制下載次數
  lastDownloadedAt DateTime?        @map("last_downloaded_at")
  failureReason    String?          @map("failure_reason")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  privacyRequest PrivacyRequest @relation(fields: [privacyRequestId], references: [id], onDelete: Cascade)
  storageObject  StorageObject? @relation(fields: [storageObjectId], references: [id], onDelete: SetNull)

  @@index([status, expiresAt]) // 過期清除 job 用
  @@index([userId, createdAt])
  @@map("data_exports")
}

// 可設定的執行依據，不是純文件記錄表：retention 相關 job 執行前都要查這張表，
// 天數/動作不寫死在程式碼常數裡（見 §7a 交付內容 4）。
model DataRetentionPolicy {
  id            String           @id @default(cuid())
  policyKey     String           @unique @map("policy_key")
  description   String
  retentionDays Int?             @map("retention_days") // null = 不自動清理（長期保留，例如 audit_logs）
  action        RetentionAction? // retentionDays 為 null 時 action 也必須是 null（見規格說明）
  isActive      Boolean          @default(true) @map("is_active")
  updatedBy     String?          @map("updated_by")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  updatedByUser User? @relation(fields: [updatedBy], references: [id], onDelete: SetNull)

  @@map("data_retention_policies")
}

// 每次 retention job 對任一筆資料真的動手都寫一筆；本表比照 audit_logs 長期保留，
// 不可被任何清理 job 清掉。
model DataPurgeLog {
  id               String          @id @default(cuid())
  policyKey        String          @map("policy_key") // 快照當下的 policy_key，不設 FK
  jobRunId         String?         @map("job_run_id")
  targetType       String          @map("target_type") // 'item_image' | 'message' | 'notification' | ...
  targetId         String          @map("target_id")
  actionTaken      RetentionAction @map("action_taken")
  skippedLegalHold Boolean         @default(false) @map("skipped_legal_hold")
  createdAt        DateTime        @default(now()) @map("created_at")

  jobRun SystemJobRun? @relation(fields: [jobRunId], references: [id], onDelete: SetNull)

  @@index([policyKey, createdAt])
  @@index([targetType, targetId])
  @@map("data_purge_logs")
}

// 機關調閱請求：不對外開放 API，一律由客服/admin 手動建檔（見規格「誰能提出」）。
// submittedBy 與 approvedBy 刻意分開且必須是不同人（雙人審核，防止單一 admin 濫權）。
model LawEnforcementRequest {
  id              String                      @id @default(cuid())
  agencyName      String                      @map("agency_name")
  caseReference   String                      @map("case_reference")
  legalBasis      String                      @map("legal_basis") // 來文所附法源條文
  requestScope    String                      @map("request_scope") // 例：「OO 使用者近 90 天私訊」
  receivedAt      DateTime                    @map("received_at") // 公文實際到站日期，可能早於建檔時間
  status          LawEnforcementRequestStatus @default(submitted)
  submittedBy     String                      @map("submitted_by")
  approvedBy      String?                     @map("approved_by")
  approvedAt      DateTime?                   @map("approved_at")
  rejectionReason String?                     @map("rejection_reason")
  notifyUser      Boolean                     @default(true) @map("notify_user") // 是否通知當事人，例外需法律依據
  notifiedAt      DateTime?                   @map("notified_at")
  createdAt       DateTime                    @default(now()) @map("created_at")
  updatedAt       DateTime                    @updatedAt @map("updated_at")

  submitter User  @relation("LawEnforcementRequestSubmitter", fields: [submittedBy], references: [id], onDelete: Cascade)
  approver  User? @relation("LawEnforcementRequestApprover", fields: [approvedBy], references: [id], onDelete: SetNull)

  targets    LawEnforcementRequestTarget[]
  documents  LawEnforcementRequestDocument[]
  events     LawEnforcementRequestEvent[]
  exports    LawEnforcementExport[]
  legalHolds LegalHold[]

  @@index([status, createdAt])
  @@map("law_enforcement_requests")
}

model LawEnforcementRequestTarget {
  id         String @id @default(cuid())
  requestId  String @map("request_id")
  targetType String @map("target_type") // user | item | conversation | message
  targetId   String @map("target_id")

  request LawEnforcementRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([targetType, targetId])
  @@index([requestId])
  @@map("law_enforcement_request_targets")
}

model LawEnforcementRequestDocument {
  id              String   @id @default(cuid())
  requestId       String   @map("request_id")
  storageObjectId String   @map("storage_object_id") // kind=law_enforcement_document
  uploadedBy      String   @map("uploaded_by")
  createdAt       DateTime @default(now()) @map("created_at")

  request       LawEnforcementRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  storageObject StorageObject         @relation(fields: [storageObjectId], references: [id], onDelete: Restrict)
  uploader      User                  @relation(fields: [uploadedBy], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@index([storageObjectId])
  @@map("law_enforcement_request_documents")
}

// 稽核用，逐筆記錄狀態轉換與備註；依 createdAt 讀出要能還原完整處理時間序。
model LawEnforcementRequestEvent {
  id        String   @id @default(cuid())
  requestId String   @map("request_id")
  action    String
  actorId   String?  @map("actor_id")
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  request LawEnforcementRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  actor   User?                 @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([requestId, createdAt])
  @@map("law_enforcement_request_events")
}

// 只有 admin 角色能取得下載連結，且每次下載寫入 LawEnforcementRequestEvent（應用層規則）。
model LawEnforcementExport {
  id              String    @id @default(cuid())
  requestId       String    @map("request_id")
  storageObjectId String    @map("storage_object_id") // kind=law_enforcement_export
  generatedAt     DateTime  @default(now()) @map("generated_at")
  expiresAt       DateTime? @map("expires_at") // 依案件，可能不設過期，由 legal_holds 保護避免誤刪

  request       LawEnforcementRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  storageObject StorageObject         @relation(fields: [storageObjectId], references: [id], onDelete: Restrict)

  @@index([requestId])
  @@map("law_enforcement_exports")
}

// 也可能源自站內檢舉/內部訴訟而建立，不一定源自警方請求，故 relatedRequestId 允許 null。
model LegalHold {
  id               String          @id @default(cuid())
  reason           String
  relatedRequestId String?         @map("related_request_id")
  status           LegalHoldStatus @default(active)
  createdBy        String          @map("created_by")
  releasedBy       String?         @map("released_by")
  releasedAt       DateTime?       @map("released_at")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  relatedRequest LawEnforcementRequest? @relation(fields: [relatedRequestId], references: [id], onDelete: SetNull)
  creator        User                   @relation("LegalHoldCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  releaser       User?                  @relation("LegalHoldReleaser", fields: [releasedBy], references: [id], onDelete: SetNull)

  targets LegalHoldTarget[]
  events  LegalHoldEvent[]

  @@index([status])
  @@map("legal_holds")
}

// isUnderLegalHold() 的核心查詢索引，必建（見 master-plan.md §7a 交付內容 5）。
model LegalHoldTarget {
  id          String @id @default(cuid())
  legalHoldId String @map("legal_hold_id")
  targetType  String @map("target_type") // user | item | conversation | message | handover_record |
  // claim_comment | direct_share | thanks_message | coupon_reveal_log | report
  targetId    String @map("target_id")

  legalHold LegalHold @relation(fields: [legalHoldId], references: [id], onDelete: Cascade)

  @@index([targetType, targetId])
  @@index([legalHoldId])
  @@map("legal_hold_targets")
}

model LegalHoldEvent {
  id          String   @id @default(cuid())
  legalHoldId String   @map("legal_hold_id")
  action      String // created / target_added / target_removed / released
  actorId     String?  @map("actor_id")
  note        String?
  createdAt   DateTime @default(now()) @map("created_at")

  legalHold LegalHold @relation(fields: [legalHoldId], references: [id], onDelete: Cascade)
  actor     User?     @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([legalHoldId, createdAt])
  @@map("legal_hold_events")
}

// ===== M8 營運強化（master-plan.md §8a、§11.1）=====

model HealthCheck {
  id        String   @id @default(cuid())
  subsystem String // "database" | "storage" | "background_jobs"（字串 key，未來加子系統不必 migration）
  status    String // "up" | "degraded" | "down"
  latencyMs Int?     @map("latency_ms") // 該次檢查耗時，例如 DB SELECT 1、MinIO headBucket 往返時間
  detail    Json? // 例如 background_jobs 記錄「距離上次 system_job_runs 成功結束幾分鐘」
  checkedAt DateTime @default(now()) @map("checked_at")

  @@index([subsystem, checkedAt]) // 儀表板依子系統畫歷史趨勢用
  @@map("health_checks")
}

// 記錄「壞事發生」，用途是除錯與異常追蹤；與 PerformanceMetric 的分工見 §8a 交付內容 3。
model ErrorLog {
  id         String   @id @default(cuid())
  source     String // "api" | "background_job" | "webhook"
  routeOrJob String?  @map("route_or_job") // 正規化後的 route path（不含動態 id）或 system_jobs.key
  message    String
  stack      String?
  context    Json? // userId、requestId 等排查用途；禁止塞入敏感個資
  occurredAt DateTime @default(now()) @map("occurred_at")

  @@index([source, occurredAt])
  @@map("error_logs")
}

// 記錄「正常運作但耗時多少」，不論成功失敗；全量記錄不設寫入門檻（見規格「取樣範圍」）。
// P95 由查詢時對原始樣本用 percentile_cont(0.95) 即時聚合算出，不另建彙總表。
model PerformanceMetric {
  id         String   @id @default(cuid())
  metricType String   @map("metric_type") // 先只做 "db_query"，"api_request" 留給之後擴充
  label      String // 正規化後的識別碼，例如 "Item.findMany"、"ClaimComment.create"
  durationMs Int      @map("duration_ms")
  isSlow     Boolean  @map("is_slow") // durationMs > 1000，即時旗標，不是統計量
  context    Json?
  recordedAt DateTime @default(now()) @map("recorded_at")

  @@index([metricType, label, recordedAt]) // 依 label 分組看趨勢
  @@index([isSlow, recordedAt]) // 儀表板快速撈「最近的慢查詢」列表
  @@map("performance_metrics")
}

// 每日快照，一次快照對每個 bucket 各寫一筆；不設保留期（需要長期趨勢，見 §8a 交付內容 3）。
model StorageUsageSnapshot {
  id            String   @id @default(cuid())
  bucket        String
  totalBytes    BigInt   @map("total_bytes")
  objectCount   Int      @map("object_count")
  orphanedBytes BigInt?  @map("orphaned_bytes") // 「孤兒用量」定義見 §8a 交付內容 2，不是 pending 那種
  orphanedCount Int?     @map("orphaned_count")
  byItemStatus  Json?    @map("by_item_status") // 例如 {"published": 12345678, "expired": 88000}
  snapshotAt    DateTime @default(now()) @map("snapshot_at")

  @@index([bucket, snapshotAt])
  @@map("storage_usage_snapshots")
}

// ===== M9 好康資訊與券票點強化（master-plan.md §9a、§11.1；使用者已核准，本次為 schema 地基） =====
//
// 內容類型判別機制（§9a 共通設計決策，已拍板）：票券／點數沿用既有 category slug 模式
// （`tickets`／`points`）＋ detail 表，比照 M3 CouponDetail，**不新增 items.type 欄位**。
// DealInfo 是「純資訊、無實體交付」內容，不進 claims/handover 狀態機，獨立成表、與 Item 平行。

enum DealSourceType {
  user_submission // 使用者投稿（研究方案 B 的 S3）
  editorial // 編輯人工收錄（研究方案 B 的 S1，見 DealSource）
}

// 審核狀態名對齊 ItemStatus 既有語意，用 pending_review，不另創 draft（§9a 已拍板）。
// 轉換：pending_review→published／pending_review→rejected（終態）／published→stale／
// stale→published（reactivate）／published→expired／stale→expired（終態）。expired／rejected
// 為終態；跳態或逆向轉換由 API 層擋（比照 M2 檢舉狀態機慣例），schema 本身不限制轉換路徑。
enum DealInfoStatus {
  pending_review
  published
  stale
  expired
  rejected
}

// S1 官方來源主檔（方案 B：編輯人工收錄自寫摘要＋導流，全程排除自動爬取），
// 由 moderator/admin 於後台維護；DealInfo（source_type=editorial）以 dealSourceId 關聯。
model DealSource {
  id            String    @id @default(cuid())
  name          String // 來源顯示名稱
  officialUrl   String    @map("official_url") // 官方固定頁 URL（導流目標）
  sourceGrade   String    @map("source_grade") // 記錄 S 分級，本章一律 "S1"，保留欄位供未來 S0/S2
  lastCheckedAt DateTime? @map("last_checked_at") // 「上次查證日期」，編輯每次人工查閱後更新
  isActive      Boolean   @default(true) @map("is_active")
  notes         String? // 收錄注意事項（如「JS SPA、活動 URL 生命週期短」）
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  dealInfos DealInfo[]

  @@map("deal_sources")
}

// 純資訊、無實體交付的好康內容，與 Item 平行、不進 claims/handover 狀態機。
model DealInfo {
  id              String         @id @default(cuid())
  title           String
  summary         String // 自寫摘要（禁複製官方圖文，純事實轉述）
  sourceUrl       String         @map("source_url") // 來源連結（原始官方 URL；短網址收錄時改存原始網址）
  sourceType      DealSourceType @map("source_type")
  dealSourceId    String?        @map("deal_source_id") // editorial 類關聯的 S1 來源；user_submission 為 null
  isNationwide    Boolean        @map("is_nationwide") // true 時忽略 DealInfoCity
  submitterId     String?        @map("submitter_id") // 使用者投稿者；editorial 收錄由編輯建立可為 null
  status          DealInfoStatus @default(pending_review)
  verifiedAt      DateTime       @map("verified_at") // 「查證日期」：建立/最近一次人工查證的時間
  expiresAt       DateTime       @map("expires_at") // 硬性 TTL 到期日（必填）
  staleReportedAt DateTime?      @map("stale_reported_at") // 最近一次被判定 stale 的時間
  publishedAt     DateTime?      @map("published_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  dealSource DealSource? @relation(fields: [dealSourceId], references: [id], onDelete: SetNull)
  submitter  User?       @relation(fields: [submitterId], references: [id], onDelete: SetNull)

  cities  DealInfoCity[]
  reports DealInfoReport[]

  @@index([status, expiresAt]) // 硬性 TTL job 掃描
  @@index([status, createdAt]) // 好康列表/瀏覽分頁（cursor）
  // M9 功能 PR（交付內容 1/2，非 schema 地基本身）新增：schema 地基當初只顧慮到列表/TTL
  // 查詢形狀，沒替 FK 欄位建索引（Postgres/Prisma 不會自動幫 FK 建索引）。這兩支查詢在
  // 功能實作時才出現：POST /api/deal-infos 的 rate limit 計數（COUNT WHERE submitterId=...
  // AND createdAt>=...，見 src/lib/rate-limit.ts 的 deal_info_create 計數器）、
  // /admin/deal-sources 後台顯示「這個來源底下有幾筆 DealInfo」（WHERE dealSourceId=...）。
  // 依 code review 裁定「只加 @@index、不動其他既有欄位」的授權範圍，僅新增這兩個索引。
  @@index([submitterId])
  @@index([dealSourceId])
  @@map("deal_infos")
}

// 多選縣市 join；DealInfo.isNationwide=true 時不建列。
model DealInfoCity {
  id         String   @id @default(cuid())
  dealInfoId String   @map("deal_info_id")
  cityId     String   @map("city_id")
  createdAt  DateTime @default(now()) @map("created_at")

  dealInfo DealInfo @relation(fields: [dealInfoId], references: [id], onDelete: Cascade)
  city     City     @relation(fields: [cityId], references: [id])

  @@unique([dealInfoId, cityId])
  @@index([cityId, dealInfoId]) // 縣市篩選（欄位順序與 unique 索引相反，服務「依縣市查好康」查詢形狀）
  @@map("deal_info_cities")
}

// 失效回報（借鏡 hotukdeals：多人回報＋狀態可逆）。一人一物一輪一次；reactivate 後 round +1，
// 讓同一人可跨輪再報，同時保留舊回報列做稽核歷史（不真的刪除）。
model DealInfoReport {
  id         String   @id @default(cuid())
  dealInfoId String   @map("deal_info_id")
  reporterId String   @map("reporter_id")
  round      Int      @default(1) // 第幾輪回報，reactivate 後遞增
  createdAt  DateTime @default(now()) @map("created_at")

  dealInfo DealInfo @relation(fields: [dealInfoId], references: [id], onDelete: Cascade)
  reporter User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@unique([dealInfoId, reporterId, round]) // 擋同一人同一輪重複回報
  @@index([reporterId, createdAt]) // rate limit deal_info_report_create 的計數查詢形狀（unique 以 dealInfoId 為前導欄，查不了單獨 reporterId）
  @@map("deal_info_reports")
}

// 優惠券「使用結果回報」（研究 02 借鏡可用/失效閉環）。一人一券一次；詳情頁只顯示聚合統計，
// 文案不得暗示平台保證有效。
enum CouponUsageResult {
  usable // 可用
  expired_or_used // 已失效
}

model CouponUsageReport {
  id         String            @id @default(cuid())
  itemId     String            @map("item_id")
  reporterId String            @map("reporter_id")
  result     CouponUsageResult
  createdAt  DateTime          @default(now()) @map("created_at")

  item     Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  reporter User @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@unique([itemId, reporterId]) // 一人一券一次
  @@map("coupon_usage_reports")
}

// 票券類型：資訊型無償轉贈媒合，明確無金額欄位；使用期限沿用 Item.expiresAt（已拍板，
// 不設自己的效期欄位，單一事實來源，M3 既有 item-expiration job 直接生效）。
model TicketDetail {
  id             String   @id @default(cuid())
  itemId         String   @unique @map("item_id")
  ticketType     String   @map("ticket_type") // 券種（如「紙本入場券」「序號券」；自由文字，不含金額）
  originPlatform String   @map("origin_platform") // 原平台聲明（如「KKTIX」「主辦官網」）
  eventName      String?  @map("event_name")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("ticket_details")
}

// 點數類型：無償贈與媒合＋引導官方 App 閉環完成轉移，平台不經手點數本身。明確無金額欄位、
// 不記錄任何會員帳號／手機號／驗證碼（個資最小化，見 §9a 交付內容 5）。
model PointDetail {
  id            String   @id @default(cuid())
  itemId        String   @unique @map("item_id")
  pointPlatform String   @map("point_platform") // 點數平台聲明（FamiPoint / OPEN POINT / 其他自由文字）
  pointAmount   Int      @map("point_amount") // 純數量，不是金額、不換算現金
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("point_details")
}
