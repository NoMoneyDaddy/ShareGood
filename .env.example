# 完整說明見 docs/plan/master-plan.md §3.4。複製為 .env 並填值。
# 注意：Auth.js v5 讀的是 AUTH_* 前綴（不是 v4 的 NEXTAUTH_*）。

# PostgreSQL（Zeabur: sharegood-postgres）
DATABASE_URL="postgresql://user:password@host:5432/sharegood"

# Auth.js v5
AUTH_SECRET="用 openssl rand -base64 32 產生"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# MinIO（Zeabur: sharegood-minio）
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET="sharegood"
S3_PUBLIC_URL="http://localhost:9000/sharegood"

# 背景 job 觸發保護
CRON_SECRET="用 openssl rand -hex 24 產生"

# M3 起：券碼加密（AES-256-GCM，見 src/lib/coupon-crypto.ts）。
# 必須是 64 個 hex 字元（32 bytes）：用 `openssl rand -hex 32` 產生。
COUPON_SECRET_KEY=""

# M4 起：Telegram Bot
TELEGRAM_BOT_TOKEN=""
TELEGRAM_WEBHOOK_SECRET=""

# seed 用：此 email 首次登入即為 admin
ADMIN_EMAIL=""

# 全站時區：所有時間顯示一律用台北時間，不用 UTC 或瀏覽器時區
TZ="Asia/Taipei"
